---
import "@styles/global.css";

import { identity } from "@lib/site";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = `${identity.name} — Portfolio`,
    description = `${identity.title} from ${identity.location}. ${identity.bio}`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="theme-color" content="#050507" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
            onload="this.rel='stylesheet'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
                rel="stylesheet"
            />
        </noscript>

        <title>{title}</title>
    </head>
    <body class="grain-overlay">
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-10000 focus:rounded focus:bg-gold focus:px-4 focus:py-2 focus:text-void focus:font-medium"
        >
            Skip to main content
        </a>

        <canvas id="ambient-particles" aria-hidden="true"></canvas>

        <slot />

        <script>
            const prefersReduced = window.matchMedia(
                "(prefers-reduced-motion: reduce)",
            ).matches;

            const observer = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("revealed");
                            observer.unobserve(entry.target);
                        }
                    }
                },
                { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
            );

            document.querySelectorAll("[data-reveal]").forEach((el) => {
                observer.observe(el);
            });

            if (!prefersReduced) {
                const parallaxEls =
                    document.querySelectorAll<HTMLElement>("[data-parallax]");
                const scrollSections =
                    document.querySelectorAll<HTMLElement>(
                        "[data-scroll-fade]",
                    );

                const updateScroll = () => {
                    const vh = window.innerHeight;

                    for (const el of parallaxEls) {
                        const speed = parseFloat(
                            el.dataset.parallaxSpeed || "0.1",
                        );
                        const rect = el.getBoundingClientRect();
                        const center = rect.top + rect.height / 2;
                        const offset = (center - vh / 2) * speed;
                        el.style.transform = `translateY(${offset}px)`;
                    }

                    for (const section of scrollSections) {
                        const rect = section.getBoundingClientRect();

                        if (rect.bottom < 0) {
                            section.style.opacity = "0";
                            section.style.transform = "scale(0.96)";
                        } else if (rect.top > vh) {
                            section.style.opacity = "0.3";
                            section.style.transform = "scale(0.98)";
                        } else {
                            const fadeIn = Math.min(
                                1,
                                (vh - rect.top) / (vh * 0.3),
                            );
                            const fadeOut = Math.min(
                                1,
                                rect.bottom / (vh * 0.3),
                            );
                            const opacity = Math.min(fadeIn, fadeOut);
                            section.style.opacity = String(
                                Math.max(0.15, opacity),
                            );
                            section.style.transform = `scale(${0.96 + opacity * 0.04})`;
                        }
                    }
                };

                let scrollRaf = 0;
                window.addEventListener(
                    "scroll",
                    () => {
                        cancelAnimationFrame(scrollRaf);
                        scrollRaf = requestAnimationFrame(updateScroll);
                    },
                    { passive: true },
                );
                updateScroll();
            }

            const SCRAMBLE_CHARS =
                "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";

            const scrambleText = (el: HTMLElement) => {
                const original =
                    el.dataset.scrambleText || el.textContent || "";
                const duration = parseInt(
                    el.dataset.scrambleDuration || "1200",
                    10,
                );
                const len = original.length;
                let frame = 0;
                const totalFrames = Math.ceil(duration / 16);

                const step = () => {
                    let output = "";
                    const progress = frame / totalFrames;

                    for (let i = 0; i < len; i++) {
                        if (original[i] === " ") {
                            output += " ";
                            continue;
                        }

                        const charProgress = i / len;
                        if (progress > charProgress + 0.3) {
                            output += original[i];
                        } else {
                            output +=
                                SCRAMBLE_CHARS[
                                    Math.floor(
                                        Math.random() * SCRAMBLE_CHARS.length,
                                    )
                                ];
                        }
                    }

                    el.textContent = output;
                    frame++;

                    if (frame <= totalFrames) {
                        requestAnimationFrame(step);
                    } else {
                        el.textContent = original;
                    }
                };

                if (!prefersReduced) {
                    requestAnimationFrame(step);
                }
            };

            const scrambleObserver = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            const el = entry.target as HTMLElement;
                            el.dataset.scrambleText = el.textContent || "";
                            const delay = parseInt(
                                el.dataset.scrambleDelay || "0",
                                10,
                            );
                            setTimeout(() => scrambleText(el), delay);
                            scrambleObserver.unobserve(el);
                        }
                    }
                },
                { threshold: 0.3 },
            );

            document.querySelectorAll("[data-scramble]").forEach((el) => {
                scrambleObserver.observe(el);
            });

            if (!prefersReduced) {
                document
                    .querySelectorAll<HTMLElement>("[data-tilt-card]")
                    .forEach((card) => {
                        const intensity = parseFloat(
                            card.dataset.tiltIntensity || "8",
                        );
                        const shine =
                            card.querySelector<HTMLElement>(".tilt-shine");

                        card.addEventListener("mousemove", (e) => {
                            const rect = card.getBoundingClientRect();
                            const x = (e.clientX - rect.left) / rect.width;
                            const y = (e.clientY - rect.top) / rect.height;

                            const rotateX = (0.5 - y) * intensity;
                            const rotateY = (x - 0.5) * intensity;

                            card.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;

                            if (shine) {
                                shine.style.setProperty(
                                    "--shine-x",
                                    `${x * 100}%`,
                                );
                                shine.style.setProperty(
                                    "--shine-y",
                                    `${y * 100}%`,
                                );
                            }
                        });

                        card.addEventListener("mouseleave", () => {
                            card.style.transform =
                                "perspective(800px) rotateX(0) rotateY(0) scale3d(1, 1, 1)";
                            card.style.transition =
                                "transform 0.5s var(--ease-sovereign)";
                            setTimeout(() => {
                                card.style.transition = "";
                            }, 500);
                        });

                        card.addEventListener("mouseenter", () => {
                            card.style.transition = "transform 0.15s ease-out";
                        });
                    });
            }

            document
                .querySelectorAll<HTMLElement>("[data-ripple]")
                .forEach((el) => {
                    el.style.position = "relative";
                    el.style.overflow = "hidden";

                    el.addEventListener("click", (e) => {
                        if (prefersReduced) return;

                        const rect = el.getBoundingClientRect();
                        const size = Math.max(rect.width, rect.height);
                        const ripple = document.createElement("span");
                        ripple.className = "ripple-effect";
                        ripple.style.width = ripple.style.height = `${size}px`;
                        ripple.style.left = `${e.clientX - rect.left - size / 2}px`;
                        ripple.style.top = `${e.clientY - rect.top - size / 2}px`;

                        el.appendChild(ripple);
                        ripple.addEventListener("animationend", () =>
                            ripple.remove(),
                        );
                    });
                });

            const counterObserver = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            const el = entry.target as HTMLElement;
                            const target = el.dataset.countTarget || "0";
                            const suffix = el.dataset.countSuffix || "";
                            const numTarget = parseInt(target, 10);
                            const duration = 2000;
                            const startTime = performance.now();

                            el.classList.add("counting");

                            const animate = (now: number) => {
                                const elapsed = now - startTime;
                                const progress = Math.min(
                                    elapsed / duration,
                                    1,
                                );

                                const eased = 1 - (1 - progress) ** 3;
                                const current = Math.floor(eased * numTarget);

                                el.textContent = `${current}${suffix}`;

                                if (progress < 1) {
                                    requestAnimationFrame(animate);
                                } else {
                                    el.textContent = `${numTarget}${suffix}`;
                                }
                            };

                            if (!prefersReduced) {
                                requestAnimationFrame(animate);
                            } else {
                                el.textContent = `${numTarget}${suffix}`;
                            }

                            counterObserver.unobserve(el);
                        }
                    }
                },
                { threshold: 0.5 },
            );

            document.querySelectorAll("[data-count-target]").forEach((el) => {
                counterObserver.observe(el);
            });

            if (!prefersReduced) {
                const particleCanvas = document.getElementById(
                    "ambient-particles",
                ) as HTMLCanvasElement;
                if (particleCanvas) {
                    const pCtx = particleCanvas.getContext("2d")!;
                    let pW = 0,
                        pH = 0;
                    let globalMouseX = -1,
                        globalMouseY = -1;

                    interface AmbientParticle {
                        x: number;
                        y: number;
                        vx: number;
                        vy: number;
                        size: number;
                        alpha: number;
                        baseAlpha: number;
                        hue: "gold" | "silver" | "blue";
                        pulseSpeed: number;
                        pulseOffset: number;
                    }

                    const ambientParticles: AmbientParticle[] = [];
                    const AMBIENT_COUNT = 50;
                    const MOUSE_RADIUS = 180;

                    const initAmbientParticles = () => {
                        ambientParticles.length = 0;
                        for (let i = 0; i < AMBIENT_COUNT; i++) {
                            const hue =
                                Math.random() < 0.6
                                    ? "gold"
                                    : Math.random() < 0.5
                                      ? "silver"
                                      : "blue";
                            ambientParticles.push({
                                x: Math.random() * pW,
                                y: Math.random() * pH,
                                vx: (Math.random() - 0.5) * 0.3,
                                vy: (Math.random() - 0.5) * 0.3 - 0.1,
                                size: 0.5 + Math.random() * 2,
                                alpha: 0,
                                baseAlpha: 0.1 + Math.random() * 0.4,
                                hue,
                                pulseSpeed: 0.5 + Math.random() * 2,
                                pulseOffset: Math.random() * Math.PI * 2,
                            });
                        }
                    };

                    const resizeParticleCanvas = () => {
                        const dpr = Math.min(window.devicePixelRatio || 1, 2);
                        pW = window.innerWidth;
                        pH = window.innerHeight;
                        particleCanvas.width = pW * dpr;
                        particleCanvas.height = pH * dpr;
                        particleCanvas.style.width = `${pW}px`;
                        particleCanvas.style.height = `${pH}px`;
                        pCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
                    };

                    let pTime = 0;

                    const renderAmbientParticles = () => {
                        pTime += 0.016;
                        pCtx.clearRect(0, 0, pW, pH);

                        for (const p of ambientParticles) {
                            if (globalMouseX >= 0) {
                                const dx = p.x - globalMouseX;
                                const dy = p.y - globalMouseY;
                                const dist = Math.sqrt(dx * dx + dy * dy);
                                if (dist < MOUSE_RADIUS) {
                                    const force =
                                        (1 - dist / MOUSE_RADIUS) * 0.8;
                                    p.vx += (dx / dist) * force;
                                    p.vy += (dy / dist) * force;
                                    p.alpha = Math.min(
                                        1,
                                        p.baseAlpha + force * 0.6,
                                    );
                                }
                            }

                            p.alpha +=
                                (p.baseAlpha +
                                    Math.sin(
                                        pTime * p.pulseSpeed + p.pulseOffset,
                                    ) *
                                        0.15 -
                                    p.alpha) *
                                0.05;

                            p.x += p.vx;
                            p.y += p.vy;

                            p.vx *= 0.98;
                            p.vy *= 0.98;

                            if (p.x < -10) p.x = pW + 10;
                            if (p.x > pW + 10) p.x = -10;
                            if (p.y < -10) p.y = pH + 10;
                            if (p.y > pH + 10) p.y = -10;

                            let color: string;
                            if (p.hue === "gold") {
                                color = `rgba(201, 168, 76, ${p.alpha})`;
                            } else if (p.hue === "silver") {
                                color = `rgba(153, 153, 173, ${p.alpha})`;
                            } else {
                                color = `rgba(74, 111, 165, ${p.alpha})`;
                            }

                            pCtx.beginPath();
                            pCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                            pCtx.fillStyle = color;
                            pCtx.fill();
                        }

                        for (let i = 0; i < ambientParticles.length; i++) {
                            for (
                                let j = i + 1;
                                j < ambientParticles.length;
                                j++
                            ) {
                                const a = ambientParticles[i]!;
                                const b = ambientParticles[j]!;
                                const dx = a.x - b.x;
                                const dy = a.y - b.y;
                                const dist = Math.sqrt(dx * dx + dy * dy);

                                if (dist < 100) {
                                    const lineAlpha =
                                        (1 - dist / 100) *
                                        0.06 *
                                        Math.min(a.alpha, b.alpha);
                                    pCtx.beginPath();
                                    pCtx.moveTo(a.x, a.y);
                                    pCtx.lineTo(b.x, b.y);
                                    pCtx.strokeStyle = `rgba(201, 168, 76, ${lineAlpha})`;
                                    pCtx.lineWidth = 0.5;
                                    pCtx.stroke();
                                }
                            }
                        }

                        requestAnimationFrame(renderAmbientParticles);
                    };

                    resizeParticleCanvas();
                    initAmbientParticles();
                    renderAmbientParticles();

                    window.addEventListener("resize", () => {
                        resizeParticleCanvas();
                        initAmbientParticles();
                    });

                    document.addEventListener("mousemove", (e) => {
                        globalMouseX = e.clientX;
                        globalMouseY = e.clientY;
                    });

                    document.addEventListener("mouseleave", () => {
                        globalMouseX = -1;
                        globalMouseY = -1;
                    });
                }
            }
        </script>
    </body>
</html>
