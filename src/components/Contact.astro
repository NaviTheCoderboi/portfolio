---
import { identity, socials } from "@lib/site";

const currentYear = new Date().getFullYear();
---

<section id="contact" class="relative py-(--spacing-section)" data-scroll-fade>
    <div class="starfield" aria-hidden="true">
        <div
            class="starfield-dot"
            style="width: 1.5px; height: 1.5px; top: 20%; left: 25%; --star-duration: 4s; --star-delay: 0.5s;"
        >
        </div>
        <div
            class="starfield-dot"
            style="width: 1px; height: 1px; top: 40%; left: 70%; --star-duration: 3s; --star-delay: 1s;"
        >
        </div>
        <div
            class="starfield-dot"
            style="width: 2px; height: 2px; top: 60%; left: 40%; --star-duration: 5s; --star-delay: 0s;"
        >
        </div>
        <div
            class="starfield-dot"
            style="width: 1px; height: 1px; top: 80%; left: 85%; --star-duration: 4.5s; --star-delay: 2s;"
        >
        </div>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 text-center">
        <div data-reveal>
            <p
                class="font-mono text-sm tracking-[0.35em] uppercase text-gold-dim mb-4"
                data-scramble
                data-scramble-delay="100"
            >
                04 / Contact
            </p>
            <div class="gold-rule-animated w-16 mx-auto mb-16" data-reveal>
            </div>
        </div>

        <h2
            class="font-display text-4xl sm:text-5xl md:text-6xl text-ivory leading-[1.1] mb-8"
            data-reveal
            data-reveal-delay="1"
            data-parallax
            data-parallax-speed="0.03"
        >
            Let&rsquo;s build
            <br />
            <span class="text-shimmer italic">something together</span>
        </h2>

        <p
            class="text-silver text-lg max-w-lg mx-auto leading-relaxed mb-12"
            data-reveal
            data-reveal-delay="2"
        >
            I'm always open to interesting projects, collaborations, and
            conversations about code. Find me on GitHub.
        </p>

        <div data-reveal data-reveal-delay="3">
            <a
                href={identity.github}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative inline-flex items-center gap-3 border border-gold/30 text-gold px-10 py-4 text-base tracking-[0.15em] uppercase transition-all duration-300 hover:bg-gold/10 hover:border-gold/60 hover:shadow-[0_0_30px_rgba(201,168,76,0.1)] focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-void"
                data-ripple
            >
                <svg
                    class="w-5 h-5"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
                <span>{identity.name}</span>
                <svg
                    class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-2"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
                </svg>
            </a>
        </div>

        <div
            class="flex items-center justify-center gap-8 mt-12"
            data-reveal
            data-reveal-delay="4"
        >
            {
                socials.map((social) => (
                    <a
                        href={social.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="relative text-sm font-mono tracking-[0.2em] uppercase text-mist transition-all duration-300 hover:text-gold hover:shadow-[0_0_12px_rgba(201,168,76,0.2)] focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-void px-3 py-2"
                        aria-label={`Visit ${social.label} profile`}
                    >
                        {social.icon}
                    </a>
                ))
            }
        </div>
    </div>
</section>

<footer class="relative border-t border-slate-light/10 py-8">
    <div
        class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
    <p class="text-sm text-silver">
        &copy; {currentYear}
        {identity.name}. All rights reserved.
    </p>
    <p class="text-sm text-silver font-mono">
        Crafted with Astro &amp; Tailwind
    </p>
    </div>
</footer>
